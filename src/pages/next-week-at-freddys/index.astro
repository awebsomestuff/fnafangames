    height: 100%;
    border: 0;
}
.post-lightbox-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0,0,0,0.85);
    z-index: 9999;
    display: flex;
    justify-content: center;
    align-items: center;
    cursor: zoom-out;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s;
}
.post-lightbox-overlay.active {
    opacity: 1;
    pointer-events: auto;
}
.post-lightbox-overlay img {
    max-width: 90%;
    max-height: 90%;
