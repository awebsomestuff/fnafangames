    color: #fff !important;
}
.post-download-cta:hover {
    background: #5a0000;
    text-decoration: none;
}

/* Stats Table */
.post-stats-table {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0;
    margin: 24px 0;
    font-size: 1em;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0,0,0,0.06);
    border: 1px solid #e0e0e0;
}
.post-stats-table thead tr {
    background: #7E4955;
}
.post-stats-table th {
    color: #fff;
    font-weight: 700;
    padding: 14px 18px;
    text-align: left;
    font-size: 0.95em;
