    letter-spacing: 0.5px;
}
.post-stats-table td {
    padding: 12px 18px;
    border-bottom: 1px solid #f0f0f0;
}
.post-stats-table td:first-child {
    font-weight: 600;
    color: #470000;
    width: 35%;
}
.post-stats-table tbody tr:nth-child(even) {
    background: #faf5f6;
}
.post-stats-table tbody tr:last-child td {
    border-bottom: none;
}
.post-stats-table tbody tr:hover {
    background: #f5e6e8;
}

/* Screenshot Gallery */
.post-screenshot-gallery {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 10px;
    margin: 24px 0;
}
.post-screenshot-gallery.gallery-2 {
    grid-template-columns: repeat(2, 1fr);
    max-width: 66%;
    margin-left: auto;
    margin-right: auto;
}
.post-screenshot-gallery.gallery-1 {
