<style is:global>
/* Override site-content width to match sonic-fangames.com (1200px content + 40px padding each side) */
.site-content {
    max-width: 1200px !important;
    padding: 30px 40px !important;
    box-sizing: content-box !important;
}

/* Styles for dynamically created elements (JS-created, no Astro scope attribute) */
.post-video-container iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: 0;
}
.post-lightbox-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0,0,0,0.85);
    z-index: 9999;
    display: flex;
    justify-content: center;
    align-items: center;
    cursor: zoom-out;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s;
}
.post-lightbox-overlay.active {
    opacity: 1;
    pointer-events: auto;
}
.post-lightbox-overlay img {
    max-width: 90%;
    max-height: 90%;
    border-radius: 8px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.4);
}
</style>

<style>
/* ========== INTERLINKING SECTION ========== */
