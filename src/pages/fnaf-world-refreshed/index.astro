}
.post-install-grid details {
    border: 1px solid #e0e0e0;
    border-radius: 8px;
    overflow: hidden;
}
.post-install-grid details:only-child {
    grid-column: 1 / -1;
}
.post-install-grid summary {
    padding: 12px 16px;
    font-weight: 600;
    cursor: pointer;
    background: #faf5f6;
    border-bottom: 1px solid #e0e0e0;
    list-style: none;
    display: flex;
    align-items: center;
    gap: 8px;
    color: #470000;
}
.post-install-grid summary::before {
    content: '▸';
    transition: transform 0.2s;
    font-size: 0.9em;
}
.post-install-grid details[open] summary::before {
    transform: rotate(90deg);
}
.post-install-grid details div {
    padding: 12px 16px;
}

