    <div class="post-video-container">
        <div class="post-yt-facade" data-vid="Pvc4ymTTeqA">
            <img src="https://i.ytimg.com/vi/Pvc4ymTTeqA/hqdefault.jpg" alt="JR's Enter the Flipside gameplay video" loading="lazy" />
