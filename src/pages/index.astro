</style>

<script is:inline>
(function(){
  var btns=document.querySelectorAll('.fg-filter');
  var cards=document.querySelectorAll('.fg-card');
  var allBtn=document.querySelector('.fg-filter[data-filter="all"]');
  var countEl=document.getElementById('fg-count');
  var emptyEl=document.querySelector('.fg-empty');
  var total=cards.length;
  var genreList=['Point & Click','Free Roam','RPG'];
  var styleList=['2D','3D'];
  var platformList=['PC','Android'];
  function getGroup(f){if(genreList.indexOf(f)!==-1)return'genre';if(styleList.indexOf(f)!==-1)return'style';if(platformList.indexOf(f)!==-1)return'platform';return null;}
  function applyFilters(){
    var active=document.querySelectorAll('.fg-filter.active:not([data-filter="all"])');
    if(active.length===0)allBtn.classList.add('active');else allBtn.classList.remove('active');
    var groups={};
    active.forEach(function(b){var f=b.getAttribute('data-filter');var g=getGroup(f);if(g){if(!groups[g])groups[g]=[];groups[g].push(f);}});
    var shown=0;
    cards.forEach(function(c){
      var cTags=[];c.querySelectorAll('.fg-tag').forEach(function(t){cTags.push(t.textContent);});
      var cGenre=c.getAttribute('data-genre')||'';
      var pass=true;
      if(groups.style){var m=false;groups.style.forEach(function(f){if(cTags.indexOf(f)!==-1)m=true;});if(!m)pass=false;}
      if(groups.genre){var m=false;groups.genre.forEach(function(f){if(cGenre===f)m=true;});if(!m)pass=false;}
      if(groups.platform){var m=false;var cPlat=c.getAttribute('data-platform')||'';groups.platform.forEach(function(f){if(cPlat.indexOf(f)!==-1)m=true;});if(!m)pass=false;}
      if(pass){c.classList.remove('fg-hidden');shown++;}else{c.classList.add('fg-hidden');}
    });
    countEl.textContent='Showing '+shown+' of '+total+' games';
    if(shown===0)emptyEl.classList.add('visible');else emptyEl.classList.remove('visible');
  }
  btns.forEach(function(b){
    b.addEventListener('click',function(){
      var f=b.getAttribute('data-filter');
      if(f==='all'){btns.forEach(function(x){x.classList.remove('active');});allBtn.classList.add('active');cards.forEach(function(c){c.classList.remove('fg-hidden');});countEl.textContent='Showing '+total+' of '+total+' games';emptyEl.classList.remove('visible');return;}
      b.classList.toggle('active');applyFilters();
    });
  });
})();
</script>

<script is:inline>
(function(){
  var overlay = document.createElement('div');
  overlay.className = 'idx-lightbox';
  document.body.appendChild(overlay);

  document.querySelectorAll('img[data-lightbox-full]').forEach(function(img){
    img.addEventListener('click', function(e){
      e.preventDefault();
      e.stopPropagation();
      var fullSrc = img.getAttribute('data-lightbox-full');
      var newImg = document.createElement('img');
      newImg.src = fullSrc;
      newImg.alt = img.alt || '';
      overlay.innerHTML = '';
      overlay.appendChild(newImg);
      overlay.classList.add('active');
    });
  });

  overlay.addEventListener('click', function(){
    overlay.classList.remove('active');
  });

  document.addEventListener('keydown', function(e){
    if(e.key === 'Escape') overlay.classList.remove('active');
  });
})();
</script>

</Layout>
