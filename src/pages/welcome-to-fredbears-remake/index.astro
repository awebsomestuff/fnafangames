<Layout title="Welcome to Fredbear's - Download Free FNAF Fan Game" description="Download Welcome to Fredbear's, a FNAF fan game. Play as William Afton against Springlock animatronics with free roam and office survival phases. Free for PC." lang="en">

<style is:global>
/* Override site-content width to match sonic-fangames.com (1200px content + 40px padding each side) */
.site-content {
    max-width: 1200px !important;
    padding: 30px 40px !important;
    box-sizing: content-box !important;
}

/* Styles for dynamically created elements (JS-created, no Astro scope attribute) */
.post-video-container iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: 0;
}
.post-lightbox-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0,0,0,0.85);
    z-index: 9999;
    display: flex;
    justify-content: center;
    align-items: center;
    cursor: zoom-out;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s;
}
.post-lightbox-overlay.active {
    opacity: 1;
    pointer-events: auto;
}
.post-lightbox-overlay img {
    max-width: 90%;
    max-height: 90%;
    border-radius: 8px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.4);
}
</style>

<style>
/* ========== INTERLINKING SECTION ========== */
.il-heading { font-size: 24px; font-weight: 800; color: #470000; margin: 48px 0 16px; }
.il-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px; margin: 0 0 40px; }
.il-card { background: #fff5f5; border: 1px solid #e0c8c8; border-radius: 12px; padding: 6px; text-align: center; }
.il-card a { text-decoration: none; color: inherit; display: block; }
.il-card a:hover { text-decoration: none; }
.il-card:hover { border-color: #470000; }
.il-img { width: 100%; height: 150px; object-fit: cover; border-radius: 10px; display: block; }
.il-title { font-size: 14px; font-weight: 600; color: #1a1d2e; margin: 6px 0 2px; line-height: 1.4; }
@media (max-width: 768px) { .il-grid { grid-template-columns: repeat(2, 1fr); } }

/* ========== NEW POST DESIGN STYLES ========== */

/* H1 - Game Title */
.post-title {
    text-align: center;
    font-size: 2.8em;
    font-weight: 800;
    color: #470000;
    margin: 20px 0 5px;
    font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    letter-spacing: -0.5px;
}
.post-title::after {
    content: '';
    display: block;
    width: 60px;
    height: 4px;
    background: #470000;
    margin: 12px auto 0;
    border-radius: 2px;
}

/* Description Section (Hero) */
.post-description {
    position: relative;
